<UserControl x:Class="AdeptTools.Launcher.Views.ImportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AdeptTools.Launcher.Controls"
             xmlns:converters="clr-namespace:AdeptTools.Launcher.Converters"
             xmlns:vm="clr-namespace:AdeptTools.Launcher.ViewModels"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver"
             DragLeave="OnDragLeave">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="PageRoot" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Header -->
                <RowDefinition Height="Auto" />  <!-- File Selection -->
                <RowDefinition Height="Auto" />  <!-- Summary -->
                <RowDefinition Height="Auto" />  <!-- Mapping Review -->
                <RowDefinition Height="Auto" />  <!-- Action Bar -->
                <RowDefinition Height="Auto" />  <!-- Results -->
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Data Import"
                               FontSize="{StaticResource FontSizeSubtitle1}"
                               FontWeight="{StaticResource FontWeightSemibold}"
                               Foreground="{StaticResource Neutral900Brush}" />

                    <!-- Mock Mode Badge -->
                    <Border Visibility="{Binding IsMockMode, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource AccentBgBrush}"
                            CornerRadius="{StaticResource RadiusDefault}"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                        <TextBlock Text="Mock Mode"
                                   FontSize="{StaticResource FontSizeCaption1}"
                                   FontWeight="{StaticResource FontWeightMedium}"
                                   Foreground="{StaticResource AccentBrush}" />
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Import metadata from Excel into Adept"
                               FontSize="{StaticResource FontSizeBody1}"
                               Foreground="{StaticResource Neutral600Brush}" />
                    <TextBlock Margin="16,0,0,0">
                        <Hyperlink Command="{Binding FetchFieldsCommand}">
                            <Run Text="Download field definitions" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- File Selection -->
            <Border Grid.Row="1"
                    Background="{StaticResource NeutralBgBrush}"
                    CornerRadius="{StaticResource RadiusS}"
                    Padding="16"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Workbook Row -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Workbook:"
                                   FontSize="{StaticResource FontSizeBody1}"
                                   Foreground="{StaticResource Neutral600Brush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding WorkbookPath, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Style="{StaticResource DefaultTextBoxStyle}"
                                 Height="{StaticResource ButtonHeightSmall}"
                                 Margin="0,0,8,0" />
                        <Button Grid.Column="2"
                                Content="Browse"
                                Command="{Binding BrowseWorkbookCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="{StaticResource ButtonHeightSmall}"
                                Padding="12,0" />
                    </Grid>

                    <!-- Config Row -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Config:"
                                   FontSize="{StaticResource FontSizeBody1}"
                                   Foreground="{StaticResource Neutral600Brush}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding ConfigPath, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Style="{StaticResource DefaultTextBoxStyle}"
                                 Height="{StaticResource ButtonHeightSmall}"
                                 Margin="0,0,8,0" />
                        <Button Grid.Column="2"
                                Content="Browse"
                                Command="{Binding BrowseConfigCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="{StaticResource ButtonHeightSmall}"
                                Padding="12,0" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Error Message -->
            <Border Grid.Row="2"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource ErrorBgBrush}"
                    CornerRadius="{StaticResource RadiusS}"
                    Padding="16"
                    Margin="0,0,0,12">
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody1}"
                           Foreground="{StaticResource ErrorTextBrush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Loading State -->
            <Border Grid.Row="2"
                    Visibility="{Binding IsFileLoading, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource NeutralBgBrush}"
                    CornerRadius="{StaticResource RadiusS}"
                    Padding="16"
                    Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Loading workbook..."
                               FontSize="{StaticResource FontSizeBody1}"
                               Foreground="{StaticResource Neutral500Brush}" />
                </StackPanel>
            </Border>

            <!-- Workbook Summary (shown when loaded) -->
            <controls:WorkbookSummaryPanel Grid.Row="2"
                                           DataContext="{Binding WorkbookSummary}"
                                           Visibility="{Binding DataContext.IsWorkbookLoaded, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                           Margin="0,0,0,12" />

            <!-- Validation Status -->
            <StackPanel Grid.Row="2" Margin="0,0,0,0"
                        Visibility="{Binding IsWorkbookLoaded, Converter={StaticResource BoolToVis}}"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right">
                <TextBlock Text="{Binding ValidationStatusText}"
                           FontSize="{StaticResource FontSizeCaption2}"
                           FontWeight="{StaticResource FontWeightMedium}"
                           Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Neutral500Brush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsValidated}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- Mapping Review -->
            <Border Grid.Row="3"
                    Visibility="{Binding IsWorkbookLoaded, Converter={StaticResource BoolToVis}}"
                    BorderBrush="{StaticResource Neutral200Brush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusS}"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <TextBlock Grid.Row="0"
                               Text="Column Mapping"
                               FontSize="{StaticResource FontSizeBody1}"
                               FontWeight="{StaticResource FontWeightSemibold}"
                               Foreground="{StaticResource Neutral900Brush}"
                               Margin="16,12,16,8" />

                    <!-- Mapping DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding MappingRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource Neutral200Brush}"
                              BorderThickness="0"
                              Background="Transparent"
                              MaxHeight="250"
                              RowBackground="{StaticResource NeutralWhiteBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Excel Column"
                                                Binding="{Binding ExcelColumn}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Margin" Value="8,0" />
                                        <Setter Property="FontWeight" Value="{StaticResource FontWeightMedium}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Adept Field"
                                                Binding="{Binding AdeptField}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Margin" Value="8,0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMissingField}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                <Setter Property="TextDecorations" Value="Underline" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Action"
                                                Binding="{Binding ActionDisplay}"
                                                Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Margin" Value="8,0" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Operator"
                                                Binding="{Binding OperatorDisplay}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Margin" Value="8,0" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Preview"
                                                Binding="{Binding PreviewValue}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Margin" Value="8,0" />
                                        <Setter Property="Foreground" Value="{StaticResource Neutral500Brush}" />
                                        <Setter Property="FontStyle" Value="Italic" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Foreground" Value="{StaticResource Neutral600Brush}" />
                                <Setter Property="FontWeight" Value="{StaticResource FontWeightSemibold}" />
                                <Setter Property="FontSize" Value="{StaticResource FontSizeCaption2}" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="Background" Value="{StaticResource NeutralBgBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Neutral200Brush}" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Neutral100Brush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSearchKey}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="BorderThickness" Value="3,0,0,0" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDoNotImport}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Neutral400Brush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="4" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{StaticResource Neutral900Brush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                    </DataGrid>

                    <!-- Mapping Footer -->
                    <TextBlock Grid.Row="2"
                               Text="{Binding MappingFooter}"
                               FontSize="{StaticResource FontSizeCaption2}"
                               Foreground="{StaticResource Neutral500Brush}"
                               Margin="16,6,16,12" />
                </Grid>
            </Border>

            <!-- Action Bar -->
            <Border Grid.Row="4"
                    Visibility="{Binding IsWorkbookLoaded, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource NeutralBgBrush}"
                    CornerRadius="{StaticResource RadiusS}"
                    Padding="12"
                    Margin="0,0,0,12">
                <WrapPanel>
                    <CheckBox IsChecked="{Binding IsDryRun}"
                              VerticalAlignment="Center"
                              Margin="0,0,16,0">
                        <TextBlock Text="Dry Run"
                                   FontSize="{StaticResource FontSizeCaption2}"
                                   Foreground="{StaticResource Neutral600Brush}" />
                    </CheckBox>

                    <Button Content="Validate"
                            Command="{Binding ValidateCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="{StaticResource ButtonHeightSmall}"
                            Padding="12,0"
                            Margin="0,0,8,0" />

                    <Button Command="{Binding RunImportCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="{StaticResource ButtonHeightSmall}"
                            Padding="12,0"
                            Margin="0,0,8,0">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#x25B6; Run Import" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDryRun}" Value="True">
                                                <Setter Property="Text" Value="&#x25B6; Dry Run" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>

                    <!-- Cancel button (visible during operation) -->
                    <Button Content="Cancel"
                            Command="{Binding CancelOperationCommand}"
                            Visibility="{Binding IsOperationRunning, Converter={StaticResource BoolToVis}}"
                            Height="{StaticResource ButtonHeightSmall}"
                            Padding="12,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}" />
                            </Style>
                        </Button.Style>
                    </Button>
                </WrapPanel>
            </Border>

            <!-- Empty State (no workbook loaded) -->
            <StackPanel Grid.Row="2" Grid.RowSpan="4"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,40,0,40">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsWorkbookLoaded}" Value="False" />
                                    <Condition Binding="{Binding IsFileLoading}" Value="False" />
                                    <Condition Binding="{Binding ErrorMessage}" Value="{x:Null}" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="&#xE8E5;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="48"
                           Foreground="{StaticResource Neutral300Brush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16" />
                <TextBlock Text="Select a workbook to begin"
                           FontSize="{StaticResource FontSizeBody2}"
                           FontWeight="{StaticResource FontWeightMedium}"
                           Foreground="{StaticResource Neutral400Brush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Browse for an Excel import workbook (.xlsx) or drag and drop"
                           FontSize="{StaticResource FontSizeCaption2}"
                           Foreground="{StaticResource Neutral400Brush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,16" />
                <Button Content="Browse"
                        Command="{Binding BrowseWorkbookCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="{StaticResource ButtonHeightSmall}"
                        Padding="20,0"
                        HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Results Panel -->
            <controls:ResultsPanel Grid.Row="5"
                                   Visibility="{Binding ShowResults, Converter={StaticResource BoolToVis}}"
                                   Margin="0,0,0,0" />

            <!-- Drag-Drop Overlay -->
            <Border x:Name="DragOverlay"
                    Grid.Row="0" Grid.RowSpan="6"
                    Visibility="Collapsed"
                    Background="#40FFFFFF"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="2"
                    CornerRadius="{StaticResource RadiusS}"
                    IsHitTestVisible="False">
                <TextBlock Text="Drop Excel workbook (.xlsx) here"
                           FontSize="{StaticResource FontSizeSubtitle1}"
                           FontWeight="{StaticResource FontWeightMedium}"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
