<Window x:Class="AdeptTools.Launcher.Controls.ConfirmDeleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AdeptTools.Launcher.ViewModels"
        xmlns:converters="clr-namespace:AdeptTools.Launcher.Converters"
        Title="{Binding TitleText}"
        Width="580" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource NeutralWhiteBrush}"
        FontFamily="{StaticResource FontFamilyPrimary}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="⚠"
                       FontSize="{StaticResource FontSizeSubtitle1}"
                       Foreground="{StaticResource WarningBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBlock Text="{Binding TitleText}"
                       FontSize="{StaticResource FontSizeSubtitle1}"
                       FontWeight="{StaticResource FontWeightSemibold}"
                       Foreground="{StaticResource Neutral900Brush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="You are about to delete the following workflows:"
                   FontSize="{StaticResource FontSizeBody1}"
                   Foreground="{StaticResource Neutral700Brush}"
                   Margin="0,0,0,12" />

        <!-- Workflow Table -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding AllWorkflows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource Neutral200Brush}"
                  BorderBrush="{StaticResource Neutral200Brush}"
                  BorderThickness="1"
                  MaxHeight="180"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="60" />
                <DataGridTextColumn Header="In-Process" Binding="{Binding InProcessCount}" Width="80" />
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="110" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- In-Process Warning -->
        <Border Grid.Row="3"
                Visibility="{Binding ShowInProcessWarning, Converter={StaticResource BoolToVis}}"
                Background="{StaticResource WarningBgBrush}"
                BorderBrush="{StaticResource WarningBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusDefault}"
                Padding="12"
                Margin="0,0,0,12">
            <TextBlock TextWrapping="Wrap"
                       FontSize="{StaticResource FontSizeCaption2}"
                       Foreground="{StaticResource WarningTextBrush}">
                <Run Text="⚠ WARNING" FontWeight="{StaticResource FontWeightSemibold}" />
                <LineBreak />
                <Run Text="{Binding TotalInProcessCount, Mode=OneWay, StringFormat='{}{0} documents currently in-process will be moved to the System Workflow and will need to be manually reassigned.'}" />
            </TextBlock>
        </Border>

        <!-- Skip Info -->
        <Border Grid.Row="4"
                Visibility="{Binding ShowSkipInfo, Converter={StaticResource BoolToVis}}"
                Background="{StaticResource Neutral100Brush}"
                CornerRadius="{StaticResource RadiusDefault}"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock FontSize="{StaticResource FontSizeCaption2}"
                           FontWeight="{StaticResource FontWeightSemibold}"
                           Foreground="{StaticResource Neutral600Brush}"
                           Margin="0,0,0,4">
                    <Run Text="ℹ" />
                    <Run Text="{Binding SkippedWorkflows.Count, Mode=OneWay, StringFormat='{}{0} workflow(s) will be SKIPPED:'}" />
                </TextBlock>
                <ItemsControl ItemsSource="{Binding SkippedWorkflows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DeleteDialogItem}">
                            <TextBlock FontSize="{StaticResource FontSizeCaption2}"
                                       Foreground="{StaticResource Neutral500Brush}"
                                       Margin="12,2,0,0">
                                <Run Text="•" />
                                <Run Text="{Binding Name, Mode=OneWay}" />
                                <Run Text="—" />
                                <Run Text="{Binding SkipReason, Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Dry Run Checkbox -->
        <CheckBox Grid.Row="5"
                  IsChecked="{Binding IsDryRun}"
                  Margin="0,0,0,20">
            <TextBlock Text="Dry Run (validate only, do not delete)"
                       FontSize="{StaticResource FontSizeBody1}"
                       Foreground="{StaticResource Neutral700Brush}" />
        </CheckBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,12,0"
                    MinWidth="80" />
            <Button Content="{Binding DeleteButtonText}"
                    Command="{Binding ConfirmCommand}"
                    IsEnabled="{Binding CanConfirm}"
                    MinWidth="160">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                        <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ErrorTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{StaticResource Neutral100Brush}" />
                                <Setter Property="Foreground" Value="{StaticResource Neutral400Brush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
