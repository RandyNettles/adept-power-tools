<UserControl x:Class="AdeptTools.Launcher.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AdeptTools.Launcher.ViewModels">
    <Grid Background="{StaticResource NeutralBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Nav Items -->
        <ItemsControl Grid.Row="0" ItemsSource="{Binding NavItems}" Margin="0,8,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:NavItem}">
                    <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            IsEnabled="{Binding IsEnabled}"
                            Cursor="Hand"
                            Height="40" HorizontalContentAlignment="Stretch">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg"
                                                    Background="{TemplateBinding Background}"
                                                    SnapsToDevicePixels="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="3" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="indicator" Grid.Column="0" Background="Transparent" />
                                                    <ContentPresenter Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{StaticResource Neutral100Brush}" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.5" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{StaticResource PrimaryLightBrush}" />
                                                    <Setter TargetName="indicator" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding IconGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" VerticalAlignment="Center"
                                       Width="24" TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Neutral500Brush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding Label}"
                                       FontSize="{StaticResource FontSizeBody1}"
                                       FontFamily="{StaticResource FontFamilyPrimary}"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Neutral600Brush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                <Setter Property="FontWeight" Value="{StaticResource FontWeightSemibold}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Bottom: version + mock mode chip -->
        <StackPanel Grid.Row="1" Margin="16,0,16,16">
            <Separator Background="{StaticResource Neutral200Brush}" Margin="0,0,0,12" />
            <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                       FontSize="{StaticResource FontSizeCaption2}"
                       Foreground="{StaticResource Neutral500Brush}"
                       FontFamily="{StaticResource FontFamilyPrimary}" />
            <!-- Mock mode chip -->
            <Border Visibility="{Binding IsMockMode, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{StaticResource AccentBgBrush}"
                    CornerRadius="{StaticResource RadiusCircle}"
                    Padding="8,3" Margin="0,6,0,0"
                    HorizontalAlignment="Left">
                <TextBlock Text="Mock Mode"
                           FontSize="{StaticResource FontSizeCaption1}"
                           FontWeight="{StaticResource FontWeightMedium}"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="{StaticResource FontFamilyPrimary}" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
