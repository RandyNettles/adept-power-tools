<UserControl x:Class="AdeptTools.Launcher.Controls.ResultsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AdeptTools.Launcher.ViewModels">

    <Border Background="{StaticResource NeutralBgBrush}"
            BorderBrush="{StaticResource Neutral200Brush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusS}"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Operation Results"
                           FontSize="{StaticResource FontSizeBody1}"
                           FontWeight="{StaticResource FontWeightSemibold}"
                           Foreground="{StaticResource Neutral900Brush}"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Content="Copy"
                        Command="{Binding CopyResultsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="{StaticResource ButtonHeightSmall}"
                        Padding="12,0"
                        FontSize="{StaticResource FontSizeCaption2}"
                        Margin="0,0,8,0" />

                <Button Grid.Column="2"
                        Content="Clear"
                        Command="{Binding ClearResultsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="{StaticResource ButtonHeightSmall}"
                        Padding="12,0"
                        FontSize="{StaticResource FontSizeCaption2}" />
            </Grid>

            <!-- Progress Bar -->
            <ProgressBar Grid.Row="1"
                         Value="{Binding ProgressPercent}"
                         Maximum="100"
                         Style="{StaticResource DefaultProgressBarStyle}"
                         Margin="0,0,0,4" />

            <!-- Progress Text -->
            <TextBlock Grid.Row="2"
                       Text="{Binding ProgressText}"
                       FontSize="{StaticResource FontSizeCaption2}"
                       Foreground="{StaticResource Neutral500Brush}"
                       Margin="0,0,0,8" />

            <!-- Result Items List -->
            <ScrollViewer Grid.Row="3"
                          MaxHeight="200"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ResultItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ResultItem}">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding StatusPrefix}"
                                           FontSize="{StaticResource FontSizeCaption2}"
                                           FontWeight="{StaticResource FontWeightSemibold}"
                                           MinWidth="44"
                                           Margin="0,0,8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:ResultStatus.Ok}">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:ResultStatus.Fail}">
                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:ResultStatus.Skip}">
                                                    <Setter Property="Foreground" Value="{StaticResource Neutral400Brush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Message}"
                                           FontSize="{StaticResource FontSizeCaption2}"
                                           Foreground="{StaticResource Neutral700Brush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
