<UserControl x:Class="AdeptTools.Launcher.Controls.WorkbookSummaryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource SuccessBgBrush}"
            BorderBrush="{StaticResource Neutral200Brush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusS}"
            Padding="16">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="&#x2139;"
                           FontSize="{StaticResource FontSizeBody1}"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Text="Workbook loaded successfully"
                           FontSize="{StaticResource FontSizeBody1}"
                           FontWeight="{StaticResource FontWeightSemibold}"
                           Foreground="{StaticResource Neutral900Brush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Property Grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Import Mode:"
                           FontSize="{StaticResource FontSizeCaption2}" Foreground="{StaticResource Neutral600Brush}" Margin="0,2" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ImportModeDisplay}"
                           FontSize="{StaticResource FontSizeCaption2}" FontWeight="{StaticResource FontWeightMedium}" Foreground="{StaticResource Neutral900Brush}" Margin="0,2" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Add If Not Found:"
                           FontSize="{StaticResource FontSizeCaption2}" Foreground="{StaticResource Neutral600Brush}" Margin="0,2" />
                <TextBlock Grid.Row="1" Grid.Column="1"
                           FontSize="{StaticResource FontSizeCaption2}" FontWeight="{StaticResource FontWeightMedium}" Foreground="{StaticResource Neutral900Brush}" Margin="0,2">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="No" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AddIfNotFound}" Value="True">
                                    <Setter Property="Text" Value="Yes" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Work Area:"
                           FontSize="{StaticResource FontSizeCaption2}" Foreground="{StaticResource Neutral600Brush}" Margin="0,2" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WorkArea}"
                           FontSize="{StaticResource FontSizeCaption2}" FontWeight="{StaticResource FontWeightMedium}" Foreground="{StaticResource Neutral900Brush}" Margin="0,2" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Data Rows:"
                           FontSize="{StaticResource FontSizeCaption2}" Foreground="{StaticResource Neutral600Brush}" Margin="0,2" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DataRowCount, StringFormat=N0}"
                           FontSize="{StaticResource FontSizeCaption2}" FontWeight="{StaticResource FontWeightMedium}" Foreground="{StaticResource Neutral900Brush}" Margin="0,2" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Search Keys:"
                           FontSize="{StaticResource FontSizeCaption2}" Foreground="{StaticResource Neutral600Brush}" Margin="0,2" />
                <TextBlock Grid.Row="4" Grid.Column="1"
                           FontSize="{StaticResource FontSizeCaption2}" FontWeight="{StaticResource FontWeightMedium}" Foreground="{StaticResource Neutral900Brush}" Margin="0,2">
                    <Run Text="{Binding SearchKeyCount, Mode=OneWay}" />
                    <Run Text=" fields: " />
                    <Run Text="{Binding SearchKeyNames, Mode=OneWay}" />
                </TextBlock>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Fill Fields:"
                           FontSize="{StaticResource FontSizeCaption2}" Foreground="{StaticResource Neutral600Brush}" Margin="0,2" />
                <TextBlock Grid.Row="5" Grid.Column="1"
                           FontSize="{StaticResource FontSizeCaption2}" FontWeight="{StaticResource FontWeightMedium}" Foreground="{StaticResource Neutral900Brush}" Margin="0,2">
                    <Run Text="{Binding FillFieldCount, Mode=OneWay}" />
                    <Run Text=" fields: " />
                    <Run Text="{Binding FillFieldNames, Mode=OneWay}" />
                </TextBlock>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Skipped:"
                           FontSize="{StaticResource FontSizeCaption2}" Foreground="{StaticResource Neutral600Brush}" Margin="0,2" />
                <TextBlock Grid.Row="6" Grid.Column="1"
                           FontSize="{StaticResource FontSizeCaption2}" FontWeight="{StaticResource FontWeightMedium}" Foreground="{StaticResource Neutral400Brush}" Margin="0,2">
                    <Run Text="{Binding SkippedCount, Mode=OneWay}" />
                    <Run Text=" columns (Do Not Import)" />
                </TextBlock>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
