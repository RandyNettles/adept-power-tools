<UserControl x:Class="AdeptTools.Launcher.Controls.StatusIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AdeptTools.Launcher.Converters">
    <UserControl.Resources>
        <converters:ConnectionStatusToColorConverter x:Key="StatusColorConverter" />
    </UserControl.Resources>
    <StackPanel Orientation="Horizontal">
        <Ellipse Width="10" Height="10"
                 Fill="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                 VerticalAlignment="Center" />
        <TextBlock Text="{Binding StatusText}"
                   FontSize="{StaticResource FontSizeBody1}"
                   FontFamily="{StaticResource FontFamilyPrimary}"
                   Foreground="{StaticResource Neutral600Brush}"
                   VerticalAlignment="Center" Margin="8,0,0,0" />
    </StackPanel>
</UserControl>
