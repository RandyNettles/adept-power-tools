<Window x:Class="AdeptTools.Launcher.Controls.UserSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AdeptTools.Launcher.ViewModels"
        Title="Select Account"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource NeutralWhiteBrush}"
        FontFamily="{StaticResource FontFamilyPrimary}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Multiple accounts found"
                   FontSize="{StaticResource FontSizeSubtitle1}"
                   FontWeight="{StaticResource FontWeightSemibold}"
                   Foreground="{StaticResource Neutral900Brush}"
                   Margin="0,0,0,8" />

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="Your identity is linked to more than one Adept account. Select the account you want to connect as."
                   FontSize="{StaticResource FontSizeBody1}"
                   Foreground="{StaticResource Neutral700Brush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />

        <!-- User List -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Users}"
                 SelectedItem="{Binding SelectedUser}"
                 BorderBrush="{StaticResource Neutral200Brush}"
                 BorderThickness="1"
                 Margin="0,0,0,20"
                 MaxHeight="220">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="8,6">
                        <TextBlock Text="{Binding UserName}"
                                   FontSize="{StaticResource FontSizeBody1}"
                                   FontWeight="{StaticResource FontWeightMedium}"
                                   Foreground="{StaticResource Neutral900Brush}" />
                        <TextBlock Text="{Binding TypeLabel}"
                                   FontSize="{StaticResource FontSizeCaption2}"
                                   Foreground="{StaticResource Neutral500Brush}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,8,0" />
            <Button Content="Connect"
                    Command="{Binding SelectCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
